# Jivetalking - Presenter Integration Tests
# Local audio files (not in git). Imported into the root justfile, so recipes run
# from the repo root where ./jivetalking lives.

# source_directory() returns the directory of THIS file
testdata := source_directory()

# Current episode (override per run, e.g. `just ep=82 process-presenters`)
ep := "83"

# Presenters processed by the batch recipes
presenters := "mark martin popey"

# Episodes processed by the `*-all` recipes
episodes_list := "68 69 70 71 72 73 74 75 76 77 78 79 80 81"

# Set diagnostics=1 (any non-empty value) to add --diagnostics: emit the .jsonl
# sidecars + before/after spectrogram PNGs. Off by default. Works on every
# analyse-*/process-* recipe, e.g. `just diagnostics=1 process-mark` or
# `just ep=82 diagnostics=1 process-presenters`.
diagnostics := ""
diag := if diagnostics == "" { "" } else { "--diagnostics" }

# Run the expensive integration tests (decode testdata/ audio + race detector;
# excluded from `just test`). Needs the gitignored testdata/ audio present.
test-integration:
    go test -tags integration -race ./cmd/jivetalking/ ./internal/processor/

# End-to-end spectrogram validation (runs the binary: gating, .md links, FLAC bit-exact)
validate-spectrograms:
    testdata/validation-0.3.1-vs-0.5.x/bin/spectrogram-validate.sh

# Analyse one presenter for the current episode
_analyse-one presenter:
    @./jivetalking -a {{ diag }} {{ testdata }}/LMP-{{ ep }}-{{ presenter }}.flac

# Process one presenter for the current episode
_process-one presenter:
    @rm -f {{ testdata }}/LMP-{{ ep }}-{{ presenter }}-*-processed.*
    @./jivetalking --debug {{ diag }} {{ testdata }}/LMP-{{ ep }}-{{ presenter }}.flac

# Analyse Mark's audio for the current episode
analyse-mark: (_analyse-one "mark")

# Analyse Martin's audio for the current episode
analyse-martin: (_analyse-one "martin")

# Analyse popey's audio for the current episode
analyse-popey: (_analyse-one "popey")

# Analyse all presenters for the current episode in one operation
analyse-presenters:
    #!/usr/bin/env bash
    set -euo pipefail
    files=()
    for presenter in {{ presenters }}; do
        f="{{ testdata }}/LMP-{{ ep }}-${presenter}.flac"
        [ -f "$f" ] && files+=("$f")
    done
    if [ ${#files[@]} -eq 0 ]; then
        echo "=== No audio for episode {{ ep }}, skipping ==="
        exit 0
    fi
    echo "=== Analysing Episode {{ ep }} ==="
    ./jivetalking -a {{ diag }} "${files[@]}"

# Analyse all presenters for every episode in batch mode
analyse-all:
    #!/usr/bin/env bash
    set -euo pipefail
    for e in {{ episodes_list }}; do
        just ep="$e" diagnostics="{{ diagnostics }}" analyse-presenters
    done

# Process Mark's audio for the current episode
process-mark: (_process-one "mark")

# Process Martin's audio for the current episode
process-martin: (_process-one "martin")

# Process popey's audio for the current episode
process-popey: (_process-one "popey")

# Process all presenters for the current episode in one operation
process-presenters:
    #!/usr/bin/env bash
    set -euo pipefail
    rm -f {{ testdata }}/LMP-{{ ep }}-*-processed.*
    files=()
    for presenter in {{ presenters }}; do
        f="{{ testdata }}/LMP-{{ ep }}-${presenter}.flac"
        [ -f "$f" ] && files+=("$f")
    done
    if [ ${#files[@]} -eq 0 ]; then
        echo "=== No audio for episode {{ ep }}, skipping ==="
        exit 0
    fi
    echo "=== Processing Episode {{ ep }} ==="
    ./jivetalking --debug {{ diag }} "${files[@]}"

# Process all presenters for every episode in batch mode
process-all:
    #!/usr/bin/env bash
    set -euo pipefail
    for e in {{ episodes_list }}; do
        just ep="$e" diagnostics="{{ diagnostics }}" process-presenters
    done
